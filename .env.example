# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Database configuration (PostgreSQL for production)
DATABASE_URL=postgresql://user:password@localhost:5432/textforge

# Public-facing base URL (used for Stripe redirect URLs)
BASE_URL=http://localhost:3000

# Required: used to HMAC-hash and validate API keys
API_KEY_SECRET=replace-with-a-long-random-secret

# ─────────────────────────────────────────────
# Redis (optional – enables shared cache + shared rate limiting)
# ─────────────────────────────────────────────
REDIS_URL=

# ─────────────────────────────────────────────
# Stripe Configuration
# ─────────────────────────────────────────────
# Secret API key (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Price IDs for each subscription tier (create products/prices in Stripe dashboard)
# Legacy: STRIPE_PRICE_ID is kept for backwards compatibility with existing deployments
STRIPE_PRO_PRICE_ID=price_your_pro_price_id           # e.g., $29/month
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id  # e.g., $99/month

# ─────────────────────────────────────────────
# Logging configuration (optional)
# ─────────────────────────────────────────────
LOG_LEVEL=info  # debug, info, warn, error

# ─────────────────────────────────────────────
# Railway-specific (set automatically by Railway)
# ─────────────────────────────────────────────
# RAILWAY_ENVIRONMENT=production
# DATABASE_URL=postgresql://...   (when using Railway Postgres add-on)
# REDIS_URL=redis://...           (when using Railway Redis add-on)
