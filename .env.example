# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public-facing base URL (used for Stripe redirect URLs)
BASE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Redis (optional – in-memory fallback if unset)
# ─────────────────────────────────────────────
REDIS_URL=

# ─────────────────────────────────────────────
# Stripe Configuration
# ─────────────────────────────────────────────
# Secret API key  (sk_test_... for test mode, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Price IDs for each subscription tier
STRIPE_PRICE_ID=price_your_pro_price_id           # legacy – kept for backwards compat
STRIPE_PRO_PRICE_ID=price_your_pro_price_id       # $29/month
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id  # $99/month

# ─────────────────────────────────────────────
# Railway-specific (set automatically by Railway)
# ─────────────────────────────────────────────
# RAILWAY_ENVIRONMENT=production
# DATABASE_URL=postgresql://...   (when using Railway Postgres add-on)
# REDIS_URL=redis://...           (when using Railway Redis add-on)
