# TextForge Dashboard Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Stripe (publishable key only — secret key stays in the backend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Domain (used in meta tags)
NEXT_PUBLIC_DOMAIN=textforge.co
